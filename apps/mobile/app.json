{
  "expo": {
    "name": "ClearMoney",
    "slug": "clearmoney",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "clearmoney",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.clearmoney.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.clearmoney.app"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
