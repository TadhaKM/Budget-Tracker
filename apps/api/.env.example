# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clearmoney?schema=public

# Supabase (Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# TrueLayer
TRUELAYER_CLIENT_ID=your-client-id
TRUELAYER_CLIENT_SECRET=your-client-secret
TRUELAYER_REDIRECT_URI=http://localhost:3001/auth/truelayer/callback
TRUELAYER_ENV=sandbox

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Encryption key for TrueLayer tokens at rest (32-byte hex)
TOKEN_ENCRYPTION_KEY=generate-a-32-byte-hex-key
