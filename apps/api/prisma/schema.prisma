generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  accounts          Account[]
  budgets           Budget[]
  recurringPayments RecurringPayment[]
  connectedBanks    ConnectedBank[]

  @@map("users")
}

model ConnectedBank {
  id                             String   @id @default(uuid()) @db.Uuid
  userId                         String   @map("user_id") @db.Uuid
  truelayerAccessTokenEncrypted  String   @map("truelayer_access_token_encrypted")
  truelayerRefreshTokenEncrypted String   @map("truelayer_refresh_token_encrypted")
  consentExpiresAt               DateTime @map("consent_expires_at")
  providerId                     String   @map("provider_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("connected_banks")
}

model Account {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  truelayerAccountId String    @unique @map("truelayer_account_id")
  bankName           String    @map("bank_name")
  accountType        String    @map("account_type")
  balance            Decimal   @db.Decimal(12, 2)
  currency           String    @default("EUR")
  lastSynced         DateTime? @map("last_synced")
  createdAt          DateTime  @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

model Transaction {
  id                     String   @id @default(uuid()) @db.Uuid
  accountId              String   @map("account_id") @db.Uuid
  truelayerTransactionId String   @unique @map("truelayer_transaction_id")
  amount                 Decimal  @db.Decimal(12, 2)
  currency               String   @default("EUR")
  description            String
  merchantName           String?  @map("merchant_name")
  category               String   @default("OTHER")
  timestamp              DateTime
  createdAt              DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, timestamp])
  @@index([category])
  @@map("transactions")
}

model Budget {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  category    String
  limitAmount Decimal  @map("limit_amount") @db.Decimal(12, 2)
  period      String
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("budgets")
}

model RecurringPayment {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  merchantName String   @map("merchant_name")
  amount       Decimal  @db.Decimal(12, 2)
  frequency    String
  lastSeen     DateTime @map("last_seen")
  category     String   @default("SUBSCRIPTIONS")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchantName])
  @@map("recurring_payments")
}
